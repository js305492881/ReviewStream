{
  "name": "git-push-review",
  "displayName": "ReviewStream/评审直达",
  "publisher": "xiesigitpush3",
  "author": "谢斯",
  "description": "在 VS Code 的源代码管理（SCM）界面为每个 Git 仓库添加一个 “Push for Review” 按钮，点击后自动 push 当前分支到远端 refs/for/分支名，适用于 Gerrit 代码评审场景，支持自动识别评审 URL、弹窗与 macOS 系统通知提示。",
  "version": "1.3.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/js305492881/ReviewStream.git"
  },
  "bugs": {
    "url": "https://github.com/js305492881/ReviewStream/issues"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/app_icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "ReviewStream",
      "properties": {
        "reviewStream.autoOpenLink": {
          "type": "boolean",
          "default": true,
          "description": "是否在推送后自动打开返回的评审链接。为 true 时自动跳转，false 时不跳转。"
        },
        "reviewStream.urlMappings": {
          "type": "array",
          "description": "可选的正则->URL 映射列表：当匹配到正则时会自动打开对应链接。每项对象包含 pattern（正则字符串）和 url（要打开的链接）。",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "pattern",
              "url"
            ],
            "additionalProperties": false
          },
          "default": [
            {
              "pattern": "gerrit3\\.alibaba-inc\\.com",
              "url": "https://banma-scm.yunos-inc.com/buildCenter/task/prebuild/add"
            }
          ]
        }
      }
    },
    "commands": [
      {
        "command": "extension.gitPushForReview",
        "title": "Push for Review",
        "icon": {
          "light": "images/Push-light.svg",
          "dark": "images/Push-dark.svg"
        }
      },
      {
        "command": "extension.gitClear",
        "title": "Clear",
        "icon": {
          "light": "images/Clear-light.svg",
          "dark": "images/Clear-dark.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "extension.gitPushForReview",
          "group": "navigation@2"
        },
        {
          "when": "scmProvider == git",
          "command": "extension.gitClear",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "package:vsix": "vsce package --no-dependencies && node ./scripts/move-vsix.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~18.19.130",
    "@types/node-notifier": "^8.0.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.1",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "vsce": "^2.15.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  }
}
